{
  "name": "hostdeck",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": "22.22.2",
    "pnpm": "10.29.2"
  },
  "scripts": {
    "check:scaffold": "node scripts/check-scaffold.mjs",
    "check:planning": "node --test scripts/check-planning.test.mjs && node scripts/check-planning.mjs",
    "check:runtime-boundary": "node scripts/check-selected-runtime-boundary.mjs",
    "check:codex-bindings": "node scripts/codex-bindings.mjs --check",
    "generate:codex-bindings": "node scripts/codex-bindings.mjs --write",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check . && node scripts/check-package-exports.mjs",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:codex": "HOSTDECK_REQUIRE_CODEX_HARDENING=1 vitest run packages/server/src/codex-runtime-hardening.smoke.test.ts",
    "smoke:codex-compatibility": "HOSTDECK_REQUIRE_CODEX_COMPATIBILITY_SMOKE=1 vitest run packages/codex-adapter/src/installed-codex.smoke.test.ts",
    "smoke:codex-ipc": "HOSTDECK_REQUIRE_CODEX_IPC_SMOKE=1 vitest run packages/codex-adapter/src/codex-ipc.smoke.test.ts",
    "smoke:codex-lifecycle": "HOSTDECK_REQUIRE_CODEX_LIFECYCLE_ACCEPTANCE=1 vitest run packages/server/src/codex-runtime-lifecycle-acceptance.smoke.test.ts",
    "smoke:codex-restart": "HOSTDECK_REQUIRE_CODEX_RESTART_SMOKE=1 vitest run packages/server/src/codex-hostdeck-restart.smoke.test.ts",
    "smoke:codex-supervisor": "HOSTDECK_REQUIRE_CODEX_SUPERVISOR_SMOKE=1 vitest run packages/server/src/codex-runtime-supervisor.smoke.test.ts",
    "smoke:codex-tui-coexistence": "HOSTDECK_REQUIRE_CODEX_TUI_COEXISTENCE_SMOKE=1 vitest run packages/server/src/codex-hostdeck-tui-coexistence.smoke.test.ts",
    "smoke:codex-threads": "HOSTDECK_REQUIRE_CODEX_THREAD_SMOKE=1 vitest run packages/codex-adapter/src/codex-thread-lifecycle.smoke.test.ts",
    "smoke:codex-semantics": "HOSTDECK_REQUIRE_CODEX_SEMANTICS_SMOKE=1 vitest run packages/codex-adapter/src/codex-operation-semantics.smoke.test.ts",
    "smoke:codex-model": "HOSTDECK_REQUIRE_CODEX_MODEL_SMOKE=1 vitest run packages/codex-adapter/src/codex-model-control.smoke.test.ts",
    "smoke:codex-goal": "HOSTDECK_REQUIRE_CODEX_GOAL_SMOKE=1 vitest run packages/codex-adapter/src/codex-goal-control.smoke.test.ts",
    "smoke:codex-plan": "HOSTDECK_REQUIRE_CODEX_PLAN_SMOKE=1 vitest run packages/codex-adapter/src/codex-plan-control.smoke.test.ts",
    "smoke:codex-usage": "HOSTDECK_REQUIRE_CODEX_USAGE_SMOKE=1 vitest run packages/codex-adapter/src/codex-usage-control.smoke.test.ts",
    "smoke:codex-compact": "HOSTDECK_REQUIRE_CODEX_COMPACT_SMOKE=1 vitest run packages/server/src/codex-compact-control.smoke.test.ts",
    "smoke:codex-skills": "HOSTDECK_REQUIRE_CODEX_SKILLS_SMOKE=1 vitest run packages/server/src/codex-skills-control.smoke.test.ts",
    "smoke:codex-prompt": "HOSTDECK_REQUIRE_CODEX_PROMPT_SMOKE=1 vitest run packages/server/src/codex-prompt-control.smoke.test.ts",
    "smoke:codex-approval": "HOSTDECK_REQUIRE_CODEX_APPROVAL_SMOKE=1 vitest run packages/server/src/codex-approval-control.smoke.test.ts",
    "smoke:codex-interrupt": "HOSTDECK_REQUIRE_CODEX_INTERRUPT_SMOKE=1 vitest run packages/server/src/codex-interrupt-control.smoke.test.ts",
    "smoke:codex-vertical": "HOSTDECK_REQUIRE_CODEX_VERTICAL_SMOKE=1 vitest run packages/server/src/codex-structured-vertical.smoke.test.ts",
    "smoke:remote-control": "HOSTDECK_REQUIRE_REMOTE_CONTROL_SMOKE=1 vitest run packages/cli/src/remote-control.smoke.test.ts",
    "smoke:pairing-android": "HOSTDECK_REQUIRE_PAIRING_ANDROID_SMOKE=1 vitest run packages/cli/src/pairing-android.smoke.test.ts",
    "smoke:android-security": "HOSTDECK_REQUIRE_ANDROID_SECURITY_ACCEPTANCE=1 vitest run packages/server/src/security-acceptance-android.smoke.test.ts",
    "test:web": "vitest run packages/web/src/view-models.test.ts packages/web/src/pairing-bootstrap.test.ts packages/test-fixtures/src/fixtures.test.ts",
    "test:browser:pairing": "playwright test --config playwright.pairing.config.ts",
    "test:e2e": "node scripts/not-implemented.mjs test:e2e REL-V1-007",
    "build": "node scripts/not-implemented.mjs build REL-V1-007",
    "smoke:local": "node scripts/not-implemented.mjs smoke:local REL-V1-006"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}

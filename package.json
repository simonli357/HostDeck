{
  "name": "hostdeck",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": "22.22.2",
    "pnpm": "10.29.2"
  },
  "scripts": {
    "check:scaffold": "node scripts/check-scaffold.mjs",
    "check:planning": "node --test scripts/check-planning.test.mjs && node scripts/check-planning.mjs",
    "check:codex-bindings": "node scripts/codex-bindings.mjs --check",
    "generate:codex-bindings": "node scripts/codex-bindings.mjs --write",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check . && node scripts/check-package-exports.mjs",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:tmux": "HOSTDECK_REQUIRE_TMUX_SMOKE=1 vitest run packages/tmux-adapter/src/index.test.ts packages/server/src/tmux-smoke.test.ts",
    "smoke:codex-compatibility": "HOSTDECK_REQUIRE_CODEX_COMPATIBILITY_SMOKE=1 vitest run packages/codex-adapter/src/installed-codex.smoke.test.ts",
    "smoke:codex-ipc": "HOSTDECK_REQUIRE_CODEX_IPC_SMOKE=1 vitest run packages/codex-adapter/src/codex-ipc.smoke.test.ts",
    "smoke:codex-threads": "HOSTDECK_REQUIRE_CODEX_THREAD_SMOKE=1 vitest run packages/codex-adapter/src/codex-thread-lifecycle.smoke.test.ts",
    "smoke:codex-semantics": "HOSTDECK_REQUIRE_CODEX_SEMANTICS_SMOKE=1 vitest run packages/codex-adapter/src/codex-operation-semantics.smoke.test.ts",
    "smoke:codex-model": "HOSTDECK_REQUIRE_CODEX_MODEL_SMOKE=1 vitest run packages/codex-adapter/src/codex-model-control.smoke.test.ts",
    "test:web": "vitest run packages/web/src/view-models.test.ts packages/test-fixtures/src/fixtures.test.ts",
    "test:e2e": "node scripts/not-implemented.mjs test:e2e REL-V1-007",
    "build": "node scripts/not-implemented.mjs build REL-V1-007",
    "smoke:local": "node scripts/not-implemented.mjs smoke:local REL-V1-006"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "26.1.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
